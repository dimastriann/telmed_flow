<odoo>
    <data noupdate="1">
        <!-- Root Menu for TelMedFlow API (optional, as FastAPI has its own menu) -->
        
        <!-- Example Endpoint Registration -->
        <record id="telmed_flow_endpoint" model="fastapi.endpoint">
            <field name="name">TelMedFlow Mobile API</field>
            <field name="app">telmed_flow</field>
            <field name="root_path">/api/v1/telmed</field>
            <field name="user_id" ref="base.user_admin"/>
        </record>
    </data>
</odoo>
